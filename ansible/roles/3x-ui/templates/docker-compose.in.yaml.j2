services:
  3xui:
    image: ghcr.io/mhsanaei/3x-ui:v3.0.1
    container_name: 3xui_app
    hostname: "{{ fqdn }}"
    expose:
      - 80
      - 443
      - 2053
      - 2096
    volumes:
      - 3xui_db:/etc/x-ui/
      - $PWD/cert/:/root/cert/
    environment:
      XRAY_VMESS_AEAD_FORCED: false
      XUI_ENABLE_FAIL2BAN: true
    tty: true
    restart: unless-stopped
    networks:
      - romashovtech_default
networks:
  romashovtech_default:
    name: romashovtech_default
    external: true
volumes:
  3xui_db:
