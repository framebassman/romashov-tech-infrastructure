services:
  3xui:
    image: ghcr.io/mhsanaei/3x-ui:v3.0.1
    container_name: 3xui_app
    hostname: "{{ fqdn }}"
    expose:
      - 6432
      - 443
    volumes:
      - $PWD/db/:/etc/x-ui/
      - $PWD/cert/:/root/cert/
    environment:
      XRAY_VMESS_AEAD_FORCED: false
      XUI_ENABLE_FAIL2BAN: true
    tty: true
    restart: unless-stopped
    networks:
      - romashovtech_default
    labels:
      - traefik.enable=true
      - traefik.tcp.routers.vless.rule=HostSNI(`in.3x.romashov.tech`)
      - traefik.tcp.routers.vless.entrypoints=https-point
      - traefik.tcp.routers.vless.tls.passthrough=true
      - traefik.tcp.services.vless.loadbalancer.server.port=443
      - traefik.http.routers.3xui.rule=Host(`in.3xui.romashov.tech`)
      - traefik.http.routers.3xui.tls=true
      - traefik.http.routers.3xui.tls.certResolver=leresolver
      - traefik.http.services.3xui.loadbalancer.server.port=6432
networks:
  romashovtech_default:
    name: romashovtech_default
    external: true
