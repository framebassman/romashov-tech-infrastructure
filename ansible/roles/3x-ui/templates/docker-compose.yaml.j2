services:
  3xui:
    image: ghcr.io/mhsanaei/3x-ui:v3.0.1
    container_name: 3xui_app
    hostname: "{{ fqdn }}"
    volumes:
      - $PWD/db/:/etc/x-ui/
      - $PWD/cert/:/root/cert/
    environment:
      XRAY_VMESS_AEAD_FORCED: false
      XUI_ENABLE_FAIL2BAN: true
    tty: true
    network_mode: host
    restart: unless-stopped
